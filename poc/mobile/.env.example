# Backend base URL (FastAPI server, internet-facing over HTTPS — decision D2).
# All endpoints live under <BACKEND_BASE_URL>/api/v1.
# For local dev against a laptop backend reached via `adb reverse tcp:8080 tcp:8080`,
# use http://localhost:8080 (requires usesCleartextTraffic — already set in debug).
BACKEND_BASE_URL=https://ironpal.example.com

# Per-user bearer token issued by the backend (founder or tester).
# In a real flow this is obtained via POST /auth/token; for POC sideload
# convenience it can be pre-seeded here.
IRONPAL_AUTH_TOKEN=

# Device role: "founder" unlocks enroll mode; "tester" is live-only (Q1/Q2).
IRONPAL_ROLE=founder
