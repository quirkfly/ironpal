# IronPal POC backend config (copy to .env). Values shown are the docker-compose defaults.

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://ironpal:ironpal@localhost:5544/ironpal_poc

# Vision / LLM
VISION_MODEL=gpt-5-nano
# Key resolution order: credentials/openai.key (repo root) → OPENAI_API_KEY below.
# Leave blank to run in mock mode (no spend) — recommended until M4 model verification (DR6).
OPENAI_API_KEY=
# Force deterministic mock vision even if a key is present:
VISION_MOCK=false

# Frame retention (decision D3): only this user's sessions may keep debug_captures.
# Leave blank to rely on role=='founder' instead.
FOUNDER_USER_ID=

PORT=8000
LOG_LEVEL=INFO
