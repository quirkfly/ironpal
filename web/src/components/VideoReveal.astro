---
// Video product module (design ref: Fitbody video module).
---
<section class="section videoblock">
  <div class="wrap">
    <div class="reveal section__head">
      <span class="kicker">See it</span>
      <h2>The reveal.</h2>
    </div>
    <div class="reveal video-frame">
      <video src="/assets/reveal.mp4" autoplay muted loop playsinline preload="metadata" poster="/assets/headband-hero.jpg"></video>
      <span class="video-frame__tag">IronPal headband — campaign footage</span>
    </div>
  </div>
</section>

<style>
  .videoblock { background: var(--bg-2); }
  .video-frame { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line-2); box-shadow: 0 50px 100px -50px rgba(0,0,0,.9), 0 0 60px -30px rgba(0,229,204,.25); }
  .video-frame video { width: 100%; height: auto; }
  .video-frame__tag { position: absolute; bottom: 14px; left: 14px; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--heading); background: rgba(0,0,0,.5); border: 1px solid var(--line); padding: 6px 11px; border-radius: 8px; backdrop-filter: blur(4px); }
  @media (prefers-reduced-motion: reduce) { .video-frame video { display: none; } }
</style>
