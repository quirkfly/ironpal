---
// WHOOP-style data modules: each pairs copy with an app-UI mockup (phone)
// showing IronPal reading the metric — not a gym photo. The UI is a
// "product interface concept", labeled as such.
const mods = [
  {
    focus: 'exercise', rev: false, kicker: 'Recognition',
    h: 'It knows what you’re doing.',
    body: 'A motion fingerprint plus the camera identify the movement automatically — no scrolling a menu to find “triceps cable pushdown” before every set.',
    bg: null,
  },
  {
    focus: 'reps', rev: true, kicker: 'Counting',
    h: 'Every rep. Even the grindy ones.',
    body: 'Sensor fusion — motion <em>and</em> vision together — counts the set, including the slow heavy reps that wrist trackers quietly miss.',
    bg: null,
  },
  {
    focus: 'weight', rev: false, kicker: 'The hard part',
    h: 'It reads the weight off the bar.',
    body: 'Straight off the stack or the plates, from your point of view — no proprietary equipment, no QR codes, no typing. The part <strong>no one has shipped</strong>, and what we’re building.',
    bg: '/assets/pov-weightstack.jpg',
  },
];
---
<section class="section appmods" id="tech">
  <div class="wrap">
    <div class="reveal section__head">
      <span class="kicker">In the app</span>
      <h2>Three numbers, logged for you.</h2>
    </div>

    {mods.map((m) => (
      <div class={`amod reveal${m.rev ? ' amod--rev' : ''}`}>
        <div class="amod__media">
          {m.bg && <img class="amod__bg" src={m.bg} alt="" aria-hidden="true" loading="lazy" />}
          <div class="phone" data-focus={m.focus}>
            <span class="phone__concept">Product interface concept</span>
            <div class="phone__screen">
              <div class="scr__top"><span class="scr__brand"><i></i>IRONPAL</span><span class="scr__live">● live</span></div>

              <div class={`scr__field scr__field--ex${m.focus === 'exercise' ? ' is-focus' : ''}`}>
                <span class="scr__lbl">Exercise</span>
                <span class="scr__ex">Triceps Cable Pushdown</span>
              </div>

              <div class="scr__stats">
                <div class={`scr__stat${m.focus === 'reps' ? ' is-focus' : ''}`}>
                  <span class="scr__lbl">Reps</span><span class="scr__big">12</span>
                </div>
                <div class={`scr__stat${m.focus === 'weight' ? ' is-focus' : ''}`}>
                  <span class="scr__lbl">Weight</span><span class="scr__big">35<small>kg</small></span>
                </div>
              </div>

              <svg class="scr__spark" viewBox="0 0 240 56" preserveAspectRatio="none" aria-hidden="true">
                <polyline points="0,40 20,38 40,20 60,42 80,18 100,44 120,16 140,46 160,18 180,42 200,22 220,40 240,30"
                          fill="none" stroke="#00E5CC" stroke-width="2" />
              </svg>

              <div class="scr__log">
                <div class="scr__row"><span>Set 1</span><span>12 × 35 kg</span></div>
                <div class="scr__row"><span>Set 2</span><span>12 × 35 kg</span></div>
                <div class="scr__row scr__row--cur"><span>Set 3</span><span>logging…</span></div>
              </div>
            </div>
          </div>
        </div>

        <div class="amod__copy">
          <span class="kicker">{m.kicker}</span>
          <h3>{m.h}</h3>
          <p set:html={m.body}></p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .amod { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px,5vw,72px); align-items: center; margin-bottom: clamp(48px,8vw,110px); }
  .amod:last-child { margin-bottom: 0; }
  .amod--rev .amod__media { order: 2; }
  .amod__media { position: relative; display: flex; justify-content: center; padding: clamp(20px,4vw,44px); border-radius: var(--radius); overflow: hidden;
    background: radial-gradient(120% 90% at 50% 0%, rgba(0,229,204,.10), transparent 55%), linear-gradient(160deg, #20203a, #14142a 60%, #0e0e1f); border: 1px solid var(--line); }
  .amod__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .14; filter: saturate(.7); z-index: 0; }
  .amod__copy h3 { font-size: clamp(26px,3.8vw,44px); margin-bottom: 16px; }
  .amod__copy p { font-size: clamp(16px,2.1vw,18px); max-width: 46ch; }

  /* phone mock */
  .phone { position: relative; z-index: 1; width: clamp(238px, 26vw, 290px); aspect-ratio: 9/18.6; border-radius: 40px; padding: 12px;
    background: linear-gradient(160deg, #2a2a3e, #0b0b16); box-shadow: 0 50px 90px -40px rgba(0,0,0,.9), inset 0 0 0 1px rgba(255,255,255,.04); }
  .phone__concept { position: absolute; top: -26px; left: 50%; transform: translateX(-50%); white-space: nowrap; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--body); }
  .phone__screen { height: 100%; border-radius: 30px; background: #101023; border: 1px solid rgba(255,255,255,.05); padding: 22px 18px 16px; display: flex; flex-direction: column; gap: 12px; overflow: hidden; }
  .scr__top { display: flex; align-items: center; justify-content: space-between; }
  .scr__brand { display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-display); font-weight: 800; letter-spacing: .1em; font-size: 12px; color: var(--heading); }
  .scr__brand i { width: 12px; height: 12px; border-radius: 50%; border: 2.5px solid var(--accent); border-bottom-color: transparent; }
  .scr__live { font-size: 10px; color: var(--accent); letter-spacing: .08em; }
  .scr__lbl { font-size: 10px; text-transform: uppercase; letter-spacing: .16em; color: var(--body); }
  .scr__field { display: flex; flex-direction: column; gap: 4px; padding: 10px 12px; border-radius: 12px; background: rgba(255,255,255,.03); border: 1px solid transparent; transition: border-color .3s, background .3s; }
  .scr__ex { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--heading); line-height: 1.15; }
  .scr__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .scr__stat { display: flex; flex-direction: column; gap: 2px; padding: 10px 12px; border-radius: 12px; background: rgba(255,255,255,.03); border: 1px solid transparent; transition: border-color .3s, background .3s; }
  .scr__big { font-family: var(--font-display); font-weight: 800; font-size: 32px; color: var(--heading); line-height: 1; }
  .scr__big small { font-size: 14px; font-weight: 600; color: var(--body); margin-left: 2px; }
  .is-focus { border-color: rgba(0,229,204,.55); background: rgba(0,229,204,.08); box-shadow: 0 0 24px -8px rgba(0,229,204,.5); }
  .is-focus .scr__big, .is-focus .scr__ex { color: var(--accent); }
  .scr__spark { width: 100%; height: 42px; opacity: .9; }
  .scr__log { margin-top: auto; display: flex; flex-direction: column; gap: 6px; }
  .scr__row { display: flex; justify-content: space-between; font-size: 12px; color: var(--body); padding: 7px 10px; border-radius: 8px; background: rgba(255,255,255,.02); }
  .scr__row--cur { color: var(--accent); background: rgba(0,229,204,.07); }

  @media (max-width: 900px) {
    .amod { display: flex; flex-direction: column; }
    .amod--rev .amod__media { order: 0; }
    .amod__copy { order: 2; }
  }
</style>
