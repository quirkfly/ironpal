---
// Full-bleed athlete hero (design ref: THE GRIND high-contrast athletic hero).
---
<section class="hero">
  <img class="hero__bg" src="/assets/hero-bench.jpg" fetchpriority="high"
       alt="Athletic male bench-pressing while wearing the IronPal headband, teal logo visible, in a warmly lit gym." />
  <div class="hero__scrim"></div>

  <div class="wrap hero__inner">
    <div class="hero__copy">
      <span class="eyebrow"><span class="dot"></span>Up to ~50% off launch price · first 200 spots</span>
      <h1>Stop logging.<br /><span class="accent">Just lift.</span></h1>
      <p class="lede">A headband that watches your set and logs the exercise, your reps, and the weight on the bar — <strong>automatically</strong>. You type nothing.</p>

      <form class="capture" id="reserve" novalidate>
        <div class="capture__row">
          <input type="email" id="email" name="email" inputmode="email" autocomplete="email"
                 placeholder="you@email.com" aria-label="Email address" required />
          <button type="submit" class="btn">Reserve Early-Bird Access</button>
        </div>
        <p class="capture__hint" id="formHint">Lock the early-bird price + a 48-hour head start before public launch.</p>
      </form>
      <p class="trust">Built by a solo founder who got tired of typing reps into an app mid-set.</p>
    </div>

    <!-- floating HUD: product interface concept -->
    <div class="hud" aria-hidden="true">
      <span class="hud__tag">Product interface concept</span>
      <div class="hud__row"><span class="hud__label">Exercise</span><span class="hud__value" id="hudExercise">—</span></div>
      <div class="hud__row"><span class="hud__label">Reps</span><span class="hud__value hud__big" id="hudReps">0</span></div>
      <div class="hud__row"><span class="hud__label">Weight</span><span class="hud__value hud__big" id="hudWeight">—</span></div>
      <div class="hud__pulse"><span></span><span></span><span></span></div>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; min-height: clamp(620px, 94vh, 920px); display: flex; align-items: center; overflow: hidden; }
  .hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 60% 35%; z-index: 0; }
  .hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(16,16,30,.96) 0%, rgba(16,16,30,.78) 38%, rgba(16,16,30,.25) 70%, rgba(16,16,30,.55) 100%),
      linear-gradient(0deg, rgba(16,16,30,.85), transparent 45%);
  }
  .hero__inner { position: relative; z-index: 2; width: 100%; padding-top: 96px; padding-bottom: 48px; display: grid; grid-template-columns: minmax(0,1fr) auto; align-items: end; gap: 40px; }
  .hero__copy { max-width: 600px; }
  .hero__copy h1 { font-size: clamp(46px, 8vw, 92px); margin: 18px 0 20px; text-shadow: 0 2px 30px rgba(0,0,0,.4); }
  .lede { font-size: clamp(17px, 2.3vw, 21px); max-width: 34ch; color: #c3c8d6; }
  .trust { font-size: 14px; color: #aab0c2; margin-top: 20px; }

  .hud {
    position: relative; z-index: 2; width: 260px; background: rgba(12,12,26,.66);
    border: 1px solid rgba(0,229,204,.3); border-radius: 14px; padding: 16px 18px 18px;
    backdrop-filter: blur(12px); box-shadow: 0 24px 60px -20px rgba(0,0,0,.7), 0 0 40px -16px rgba(0,229,204,.4);
  }
  .hud__tag { display: block; font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--body); margin-bottom: 8px; }
  .hud__row { display: flex; align-items: baseline; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid var(--line); }
  .hud__row:last-of-type { border-bottom: 0; }
  .hud__label { font-size: 11px; text-transform: uppercase; letter-spacing: .16em; color: var(--body); }
  .hud__value { font-family: var(--font-display); font-weight: 700; color: var(--heading); font-size: 16px; text-align: right; transition: opacity .3s; }
  .hud__value.is-pending { color: var(--body); opacity: .5; }
  .hud__big { font-size: 28px; color: var(--accent); }
  .hud__pulse { display: flex; gap: 5px; margin-top: 12px; align-items: flex-end; height: 20px; }
  .hud__pulse span { flex: 1; background: linear-gradient(var(--accent), var(--accent-dim)); border-radius: 2px; opacity: .8; animation: eq 1.1s ease-in-out infinite; }
  .hud__pulse span:nth-child(2) { animation-delay: .18s; } .hud__pulse span:nth-child(3) { animation-delay: .36s; }
  @keyframes eq { 0%,100% { height: 30%; } 50% { height: 100%; } }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; align-items: start; }
    .hud { display: none; }
  }
  @media (max-width: 540px) {
    .capture__row { flex-direction: column; }
    .capture :global(.btn) { width: 100%; }
  }
</style>

<script>
  // HUD demo loop — product interface concept (not shipped UI).
  const ex = document.getElementById('hudExercise');
  const reps = document.getElementById('hudReps');
  const weight = document.getElementById('hudWeight');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (ex && reps && weight && !reduce) {
    const EXERCISE = 'Triceps Cable Pushdown', REPS = 5, WEIGHT = '10 kg';
    let timers = [];
    const clearAll = () => { timers.forEach(clearTimeout); timers = []; };
    const pend = (el, t) => { el.textContent = t; el.classList.add('is-pending'); };
    const set = (el, t) => { el.textContent = t; el.classList.remove('is-pending'); };

    function cycle() {
      clearAll();
      pend(ex, 'reading…'); reps.textContent = '0'; reps.classList.remove('is-pending'); pend(weight, '—');
      timers.push(setTimeout(() => set(ex, EXERCISE), 1100));
      for (let i = 1; i <= REPS; i++) timers.push(setTimeout(() => (reps.textContent = String(i)), 1700 + i * 460));
      timers.push(setTimeout(() => pend(weight, 'reading…'), 1700 + REPS * 460 + 350));
      timers.push(setTimeout(() => set(weight, WEIGHT), 1700 + REPS * 460 + 1300));
      timers.push(setTimeout(cycle, 1700 + REPS * 460 + 4200));
    }

    const hud = document.querySelector('.hud');
    if ('IntersectionObserver' in window && hud) {
      new IntersectionObserver((entries) => {
        entries.forEach((e) => (e.isIntersecting ? cycle() : clearAll()));
      }, { threshold: 0.3 }).observe(hud);
    } else { cycle(); }
  }
</script>
