---
// Oversized editorial stat band (design ref: Fitbody / Essor numerals).
const stats = [
  { n: '3', label: 'numbers logged', sub: 'exercise · reps · weight' },
  { n: '0', label: 'taps per set', sub: 'nothing to type' },
  { n: '∞', label: 'sets, hands-free', sub: 'free weights & machines' },
];
---
<section class="section stats">
  <div class="wrap stats__grid">
    {stats.map((s) => (
      <div class="stat reveal">
        <span class="stat__n">{s.n}</span>
        <span class="stat__label">{s.label}</span>
        <span class="stat__sub">{s.sub}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats { padding-block: clamp(56px, 9vw, 110px); }
  .stats__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(24px, 5vw, 56px); }
  .stat { display: flex; flex-direction: column; gap: 6px; text-align: center; position: relative; }
  .stat:not(:last-child)::after { content: ""; position: absolute; right: calc(clamp(24px,5vw,56px) / -2); top: 14%; bottom: 14%; width: 1px; background: var(--line); }
  .stat__n { font-family: var(--font-display); font-weight: 300; font-size: clamp(72px, 12vw, 150px); line-height: 1; letter-spacing: -0.04em; color: var(--heading); }
  .stat__label { font-family: var(--font-display); font-weight: 700; font-size: clamp(15px, 2vw, 19px); color: var(--accent); }
  .stat__sub { font-size: 14px; color: var(--body); }
  @media (max-width: 700px) {
    .stats__grid { grid-template-columns: 1fr; gap: 36px; }
    .stat:not(:last-child)::after { display: none; }
  }
</style>
