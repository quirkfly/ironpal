---
import Brand from './Brand.astro';
---
<footer class="footer">
  <div class="wrap footer__inner">
    <Brand />
    <p class="footer__mission">A headband that logs your lift — so you don't have to.</p>
    <p class="footer__legal">In development · © IronPal</p>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--line); padding-block: 44px; }
  .footer__inner { display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center; }
  .footer__mission { font-size: 15px; color: var(--body); }
  .footer__legal { font-size: 13px; color: #6b7088; letter-spacing: .04em; }
</style>
