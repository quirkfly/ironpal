---
// The "Iron Ring" mark (docs/logo-design-concepts.md — sole selected logo):
// teal ring with a bottom gap + a lens dot, beside the IRONPAL wordmark.
---
<a class="brand" href="#top" aria-label="IronPal home">
  <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
    <circle cx="16" cy="16" r="11" fill="none" stroke="#00E5CC" stroke-width="4" stroke-dasharray="62 10" transform="rotate(110 16 16)"></circle>
    <circle cx="16" cy="7" r="2.4" fill="#00E5CC"></circle>
  </svg>
  <span class="brand__word">IRONPAL</span>
</a>

<style>
  .brand { display: inline-flex; align-items: center; gap: 10px; }
  .brand__mark { width: 28px; height: 28px; }
  .brand__word {
    font-family: var(--font-display); font-weight: 800; letter-spacing: 0.12em;
    color: var(--heading); font-size: 18px;
  }
</style>
