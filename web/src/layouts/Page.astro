---
import '../styles/global.css';

const ORIGIN = 'https://ironpal.co';
const {
  title       = 'IronPal — Stop logging. Just lift.',
  description = 'A headband that watches your set and logs the exercise, your reps, and the weight on the bar — automatically. You type nothing.',
  ogImage     = '/og.jpg',
  ogImageAlt  = 'IronPal — the headband that logs your exercise, reps and weight automatically.',
  pathname    = '/',
} = Astro.props;

const absoluteUrl   = `${ORIGIN}${pathname}`;
const absoluteImage = ogImage.startsWith('http') ? ogImage : `${ORIGIN}${ogImage}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl} />

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='11' fill='none' stroke='%2300E5CC' stroke-width='4' stroke-dasharray='62 10' transform='rotate(110 16 16)'/%3E%3Ccircle cx='16' cy='7' r='2.4' fill='%2300E5CC'/%3E%3C/svg%3E" />

    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="IronPal" />
    <meta property="og:url"         content={absoluteUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"            content={absoluteImage} />
    <meta property="og:image:secure_url" content={absoluteImage} />
    <meta property="og:image:type"       content="image/jpeg" />
    <meta property="og:image:width"      content="1200" />
    <meta property="og:image:height"     content="630" />
    <meta property="og:image:alt"        content={ogImageAlt} />
    <meta property="og:locale"      content="en_US" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absoluteImage} />
    <meta name="twitter:image:alt"   content={ogImageAlt} />

    <meta name="theme-color" content="#1A1A2E" />
  </head>
  <body>
    <slot />

    <script>
      // ── sticky nav ─────────────────────────────────────────────
      const nav = document.getElementById('nav');
      const onScroll = () => nav && nav.classList.toggle('is-stuck', window.scrollY > 12);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // ── scroll reveal ──────────────────────────────────────────
      const reveals = document.querySelectorAll('.reveal');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
        reveals.forEach((el) => io.observe(el));
      }

      // ── "Reserve your spot" → focus the hero email field ───────
      document.querySelectorAll('.js-focus-email').forEach((a) => {
        a.addEventListener('click', () => {
          const input = document.getElementById('email');
          if (input) setTimeout(() => input.focus(), 500);
        });
      });

      // ── email capture (both forms) ─────────────────────────────
      // Wire to your ESP: set ESP_ENDPOINT to a POST URL accepting
      // { email, source }, or swap the <form> for the ESP's embed.
      const ESP_ENDPOINT = '';
      const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      function submit(email, source) {
        if (!ESP_ENDPOINT) return new Promise((res) => setTimeout(res, 650));
        return fetch(ESP_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source }),
        }).then((r) => { if (!r.ok) throw new Error('bad status'); });
      }

      function wireForm(formId, hintId, source) {
        const form = document.getElementById(formId);
        if (!form) return;
        const hint = document.getElementById(hintId);
        const input = form.querySelector('input[type="email"]');
        const defaultHint = hint ? hint.textContent : '';

        form.addEventListener('submit', (ev) => {
          ev.preventDefault();
          const email = (input.value || '').trim();
          if (!EMAIL_RE.test(email)) {
            input.classList.add('is-error');
            if (hint) { hint.textContent = "That email doesn't look right — mind checking it?"; hint.classList.add('is-error'); hint.classList.remove('is-ok'); }
            input.focus();
            return;
          }
          input.classList.remove('is-error');
          if (hint) { hint.classList.remove('is-error'); hint.textContent = 'Reserving your spot…'; }
          submit(email, source).then(() => {
            form.classList.add('is-done');
            if (hint) { hint.classList.add('is-ok'); hint.textContent = "You're in. Early-bird price + 48-hour head start locked — check your inbox."; }
          }).catch(() => {
            if (hint) { hint.classList.add('is-error'); hint.textContent = 'Something went wrong — try again in a moment.'; }
          });
        });

        input.addEventListener('input', () => {
          if (!input.classList.contains('is-error')) return;
          input.classList.remove('is-error');
          if (hint) { hint.classList.remove('is-error'); hint.textContent = defaultHint; }
        });
      }

      wireForm('reserve', 'formHint', 'landing_page');
      wireForm('reserve2', 'formHint2', 'landing_page_footer');
    </script>
  </body>
</html>
